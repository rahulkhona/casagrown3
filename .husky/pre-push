#!/bin/sh

# ═══════════════════════════════════════════════════════════════════
# Pre-push hook — Full E2E test suite
# Manages dev servers, emulators/simulators, runs all tests.
# Shuts down heavy processes (emulators) before web tests,
# boots iOS simulator for mobile tests, then restores state.
# ═══════════════════════════════════════════════════════════════════

set -e

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

# Track PIDs and state so we can clean up on exit
PIDS_TO_KILL=""
SUPABASE_STARTED_BY_US=false
ANDROID_WAS_RUNNING=false
ANDROID_EMU_NAME=""

cleanup() {
    echo ""
    echo "🧹 Cleaning up..."
    for pid in $PIDS_TO_KILL; do
        kill "$pid" 2>/dev/null && echo "   Stopped background process $pid"
    done

    if [ "$SUPABASE_STARTED_BY_US" = true ]; then
        echo "   Stopping Supabase..."
        supabase stop 2>/dev/null || true
    fi

    # Restart Android emulator if it was running before we shut it down
    if [ "$ANDROID_WAS_RUNNING" = true ] && [ -n "$ANDROID_EMU_NAME" ]; then
        echo "   Restarting Android emulator ($ANDROID_EMU_NAME)..."
        emulator -avd "$ANDROID_EMU_NAME" -no-snapshot-load > /dev/null 2>&1 &
    fi

    echo "🧹 Cleanup complete."
}
trap cleanup EXIT

# ─── Helpers ──────────────────────────────────────────────────────

wait_for_port() {
    local port=$1
    local label=$2
    local timeout=${3:-60}
    local elapsed=0
    echo "   Waiting for $label on port $port..."
    while ! curl -s "http://localhost:$port" > /dev/null 2>&1; do
        sleep 2
        elapsed=$((elapsed + 2))
        if [ "$elapsed" -ge "$timeout" ]; then
            echo "❌ Timed out waiting for $label on port $port"
            exit 1
        fi
    done
    echo "   ✓ $label ready on port $port"
}

is_port_in_use() {
    lsof -i :"$1" -sTCP:LISTEN > /dev/null 2>&1
}

echo "🔍 Running pre-push checks..."
echo ""

# ═══════════════════════════════════════════════════════════════════
# PHASE 0: Shut down resource-heavy processes for web tests
# ═══════════════════════════════════════════════════════════════════

echo "━━━ Phase 0: Resource Management ━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# Shut down Android emulator if running (saves ~2GB RAM + CPU)
ANDROID_EMU_NAME=$(adb shell getprop ro.boot.qemu.avd_name 2>/dev/null | tr -d '\r' || true)
if [ -n "$ANDROID_EMU_NAME" ]; then
    ANDROID_WAS_RUNNING=true
    echo "   Shutting down Android emulator ($ANDROID_EMU_NAME) to free resources..."
    adb emu kill 2>/dev/null || true
    sleep 3
    echo "   ✓ Android emulator stopped"
else
    echo "   ✓ No Android emulator running"
fi

echo ""

# ═══════════════════════════════════════════════════════════════════
# PHASE 1: Unit Tests (no servers needed)
# ═══════════════════════════════════════════════════════════════════

echo "━━━ Phase 1: Unit Tests ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

echo "📋 [1/5] Community App unit tests (jest)..."
yarn workspace @casagrown/app jest --passWithNoTests --bail 2>&1 || {
    echo "❌ Community App unit tests failed — push aborted."
    exit 1
}

echo "📋 [2/5] Community Voice unit tests (vitest)..."
cd apps/next-community-voice && npx vitest run --reporter=dot 2>&1 || {
    echo "❌ Community Voice unit tests failed — push aborted."
    exit 1
}
cd "$ROOT_DIR"

echo ""

# ═══════════════════════════════════════════════════════════════════
# PHASE 1.5: Supabase (database, auth, edge functions, realtime)
# ═══════════════════════════════════════════════════════════════════

echo "━━━ Infrastructure: Supabase ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if supabase status > /dev/null 2>&1; then
    echo "   ✓ Supabase already running"
else
    echo "   Starting Supabase (db, auth, edge functions, realtime, storage)..."
    supabase start 2>&1 || {
        echo "❌ Failed to start Supabase — push aborted."
        exit 1
    }
    SUPABASE_STARTED_BY_US=true
    echo "   ✓ Supabase started"
fi

echo ""

# ═══════════════════════════════════════════════════════════════════
# PHASE 2: Playwright E2E (web tests — emulators already shut down)
# ═══════════════════════════════════════════════════════════════════

echo "━━━ Phase 2: Playwright E2E (Web) ━━━━━━━━━━━━━━━━━━━━━━━━━━"

# --- Start Community Voice dev server (port 3002) if not running ---
if is_port_in_use 3002; then
    echo "   ✓ Community Voice dev server already running on 3002"
else
    echo "   Starting Community Voice dev server (port 3002)..."
    cd apps/next-community-voice && yarn dev > /dev/null 2>&1 &
    PIDS_TO_KILL="$PIDS_TO_KILL $!"
    cd "$ROOT_DIR"
    wait_for_port 3002 "Community Voice" 90
fi

echo "🎭 [3/5] Community Voice Playwright E2E tests..."
cd apps/next-community-voice && npx playwright test --reporter=dot 2>&1 || {
    echo "❌ Community Voice Playwright tests failed — push aborted."
    exit 1
}
cd "$ROOT_DIR"

# --- Start Community Web dev server (port 3000) if not running ---
if is_port_in_use 3000; then
    echo "   ✓ Community Web dev server already running on 3000"
else
    echo "   Starting Community Web dev server (port 3000)..."
    yarn web > /dev/null 2>&1 &
    PIDS_TO_KILL="$PIDS_TO_KILL $!"
    wait_for_port 3000 "Community Web" 90
fi

echo "🎭 [4/5] Community Web Playwright E2E tests..."
npx playwright test --config=e2e/playwright/playwright.config.ts --reporter=dot 2>&1 || {
    echo "❌ Community Web Playwright tests failed — push aborted."
    exit 1
}

# ═══════════════════════════════════════════════════════════════════
# PHASE 3: Maestro Mobile E2E (iOS simulator)
# ═══════════════════════════════════════════════════════════════════

echo ""
echo "━━━ Phase 3: Maestro Mobile E2E ━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# Check if maestro CLI is available
if ! command -v maestro > /dev/null 2>&1; then
    echo "   ⚠️  Maestro CLI not found — skipping mobile E2E tests."
else
    # Kill stale XCTest/Maestro processes that can block the iOS driver
    pkill -f "XCTRunner" 2>/dev/null || true
    pkill -f "maestro" 2>/dev/null || true
    sleep 1

    # Find a booted iOS simulator, or boot one if available
    IOS_UDID=$(xcrun simctl list devices | grep "Booted" | head -1 | grep -oE '[0-9A-F]{8}-[0-9A-F]{4}-[0-9A-F]{4}-[0-9A-F]{4}-[0-9A-F]{12}' || true)

    if [ -z "$IOS_UDID" ]; then
        # Try to find an available iPhone simulator and boot it
        IOS_UDID=$(xcrun simctl list devices available | grep "iPhone" | head -1 | grep -oE '[0-9A-F]{8}-[0-9A-F]{4}-[0-9A-F]{4}-[0-9A-F]{4}-[0-9A-F]{12}' || true)
        if [ -n "$IOS_UDID" ]; then
            echo "   Booting iOS simulator ($IOS_UDID)..."
            xcrun simctl boot "$IOS_UDID" 2>/dev/null || true
            sleep 5
            echo "   ✓ iOS simulator booted"
        fi
    fi

    if [ -n "$IOS_UDID" ]; then
        echo "📱 [5/5] Maestro E2E tests (iOS: $IOS_UDID)..."
        MAESTRO_DRIVER_STARTUP_TIMEOUT=120000 maestro test --udid "$IOS_UDID" .maestro/ 2>&1 || {
            echo "❌ Maestro E2E tests failed — push aborted."
            exit 1
        }
    else
        echo "   ⚠️  No iOS simulator found — skipping Maestro tests."
    fi
fi

# ═══════════════════════════════════════════════════════════════════
# Done
# ═══════════════════════════════════════════════════════════════════

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "✅ All pre-push checks passed!"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
